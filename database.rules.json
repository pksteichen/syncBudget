{
  "rules": {
    "groups": {
      "$groupId": {
        "presence": {
          ".read": "auth != null",
          "$deviceId": {
            ".write": "auth != null",
            ".validate": "newData.hasChildren(['online', 'lastSeen', 'deviceName']) && newData.child('online').isBoolean() && newData.child('lastSeen').isNumber()"
          }
        }
      }
    },
    ".read": false,
    ".write": false
  }
}
