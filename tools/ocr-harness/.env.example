# Copy to .env and fill in keys.
#
# Gemini key — required. Generate at https://aistudio.google.com/app/apikey
# You must be on a paid (Blaze-linked) project for the no-training guarantee.
GEMINI_API_KEY=

# Anthropic key — optional. Leave unset to skip the Anthropic path.
# Generate at https://console.anthropic.com/settings/keys (separate from claude.ai billing).
ANTHROPIC_API_KEY=

# Model overrides (optional; defaults shown).
# GEMINI_MODEL=gemini-2.5-flash
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
