<?xml version="1.0" encoding="utf-8"?>
<com.google.android.gms.ads.nativead.NativeAdView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/native_ad_view"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:orientation="horizontal">

        <!-- LEFT COL — 58×70 dp: 40 dp icon centered + 15 dp CTA centered.
             5 / 40 / 5 / 15 / 5 = 70 dp. -->
        <LinearLayout
            android:layout_width="58dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="5dp"
            android:paddingBottom="5dp">

            <ImageView
                android:id="@+id/native_ad_icon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginBottom="5dp"
                android:scaleType="fitCenter"
                android:contentDescription="@null" />

            <Button
                android:id="@+id/native_ad_cta"
                android:layout_width="wrap_content"
                android:layout_height="15dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="0dp"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:background="@drawable/native_ad_cta_bg"
                android:stateListAnimator="@null"
                android:includeFontPadding="false" />
        </LinearLayout>

        <!-- CENTER COL — 5 rows (advertiser, headline, 3 body lines).
             Sized so up to 90-char body fits at 320 dp screens (center col
             width ~204 dp − 8 dp padding = 196 dp; 10sp × 0.55 = 5.5 dp/char
             → ~36 chars/line × 3 = 108 char cap). Center-justified, compact
             line spacing via includeFontPadding=false. -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="4dp">

            <TextView
                android:id="@+id/native_ad_advertiser"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textStyle="bold"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:includeFontPadding="false" />

            <TextView
                android:id="@+id/native_ad_headline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:includeFontPadding="false" />

            <TextView
                android:id="@+id/native_ad_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="10sp"
                android:gravity="center"
                android:maxLines="3"
                android:ellipsize="end"
                android:includeFontPadding="false" />
        </LinearLayout>

        <!-- RIGHT COL — 58×70 dp: Ad badge + AdChoices in top row, then
             store / price / stars stacked. 5 / 12 / 4 / 12 / 4 / 12 / 4 / 12 / 5 = 70 dp.
             "Google Play" pill at 8sp ≈ 54 dp wide, fits 58 dp col with 2 dp side slack. -->
        <LinearLayout
            android:layout_width="58dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="5dp"
            android:paddingBottom="5dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/native_ad_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ad"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:background="@drawable/native_ad_badge_bg"
                    android:paddingHorizontal="4dp"
                    android:paddingVertical="0dp"
                    android:includeFontPadding="false" />

                <com.google.android.gms.ads.nativead.AdChoicesView
                    android:id="@+id/native_ad_choices"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/native_ad_store"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="8sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/native_ad_overlay_bg"
                android:paddingHorizontal="4dp"
                android:paddingVertical="0dp"
                android:visibility="gone"
                android:includeFontPadding="false" />

            <TextView
                android:id="@+id/native_ad_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="8sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/native_ad_overlay_bg"
                android:paddingHorizontal="4dp"
                android:paddingVertical="0dp"
                android:visibility="gone"
                android:includeFontPadding="false" />

            <TextView
                android:id="@+id/native_ad_star"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="8sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/native_ad_overlay_bg"
                android:paddingHorizontal="4dp"
                android:paddingVertical="0dp"
                android:visibility="gone"
                android:includeFontPadding="false" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.gms.ads.nativead.NativeAdView>
